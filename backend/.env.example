# Copy to .env and fill in. Never commit the real .env.

# Postgres connection (use for production with Neon).
# For local dev without Docker, use SQLite: sqlite:///studybuddy.db
DATABASE_URL=sqlite:///studybuddy.db

# Get a free key at https://console.groq.com  → API Keys
GROQ_API_KEY=your_groq_api_key_here

# Current Groq models (verify at https://console.groq.com/docs/models):
#   llama-3.3-70b-versatile  (higher quality)
#   llama-3.1-8b-instant     (faster, cheaper on rate limits)
GROQ_MODEL=llama-3.3-70b-versatile

# Comma-separated list of allowed frontend origins for CORS.
FRONTEND_ORIGINS=http://localhost:3000

# Qdrant vector DB (local docker-compose default below).
# For Qdrant Cloud, paste your cluster URL and API key from https://cloud.qdrant.io
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
