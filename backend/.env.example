# Copy to .env and fill in. Never commit the real .env.

# Postgres connection (local docker-compose default below).
# For Neon/Railway, paste their connection string (use the +psycopg2 driver).
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/studybuddy

# Get a free key at https://console.groq.com  → API Keys
GROQ_API_KEY=your_groq_api_key_here

# Current Groq models (verify at https://console.groq.com/docs/models):
#   llama-3.3-70b-versatile  (higher quality)
#   llama-3.1-8b-instant     (faster, cheaper on rate limits)
GROQ_MODEL=llama-3.3-70b-versatile

# Comma-separated list of allowed frontend origins for CORS.
FRONTEND_ORIGINS=http://localhost:3000
