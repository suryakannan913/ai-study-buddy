# Copy to .env and fill in. Never commit the real .env.

# Postgres connection (use for production with Neon).
# For local dev without Docker, use SQLite: sqlite:///studybuddy.db
DATABASE_URL=sqlite:///studybuddy.db

# LLM API Key (choose one, priority order):
# Option 1: Mistral (fastest & smartest) - Get free key at https://console.mistral.ai
MISTRAL_API_KEY=your_mistral_api_key_here

# Option 2: Together AI (Llama) - Get free key at https://www.together.ai
TOGETHER_API_KEY=your_together_api_key_here

# Option 3: Groq (very fast) - Get free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Comma-separated list of allowed frontend origins for CORS.
FRONTEND_ORIGINS=http://localhost:3000

# Qdrant vector DB (local docker-compose default below).
# For Qdrant Cloud, paste your cluster URL and API key from https://cloud.qdrant.io
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
